# Project
PROJECT_NAME=API Gateway
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=True

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Database
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=auth_pass
POSTGRES_DB=auth_db
DATABASE_URL=postgresql://auth_user:auth_pass@postgres:5432/auth_db

# JWT - must be identical across all services
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost"]

# Service Discovery
SERVICE_NAME=auth-service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001

# API Gateway - backend URLs
AUTH_SERVICE_URL=http://auth-service:8001

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
